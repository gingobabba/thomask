# Copy to .env and fill in. Never commit your real .env (it's gitignored).

# Required: your Anthropic API key. Powers the turn optimizer, rules search,
# and level-up advisor.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which model the proxy uses. Set to a model your key can access.
CLAUDE_MODEL=claude-sonnet-5

# Optional: Express server port (self-hosting only).
PORT=8787
